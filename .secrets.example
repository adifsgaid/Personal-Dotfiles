# ~/.secrets — sourced by .zshrc and .bashrc.
# Copy this file to ~/.secrets and fill in real values. NEVER commit ~/.secrets.

# Railway account tokens (used by adreel_ssh / promptzone_ssh aliases)
export ADREEL_RAILWAY_TOKEN=""
export PROMPTZONE_RAILWAY_TOKEN=""

# MCP tokens
export MCP_APPSIGNAL_TOKEN=""
export MCP_METABASE_TOKEN=""

# Stripe (local webhook endpoint secret)
export STRIPE_ENDPOINT_SECRET=""

# PromptZone Postgres (Railway) — used by promptzone_psql function
export PROMPTZONE_PG_HOST=""
export PROMPTZONE_PG_PORT=""
export PROMPTZONE_PG_USER=""
export PROMPTZONE_PG_DB=""
export PROMPTZONE_PG_PASSWORD=""
